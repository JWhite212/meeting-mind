{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Context Recall",
  "version": "0.1.0",
  "identifier": "dev.jamiewhite.contextrecall",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Context Recall",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ws://127.0.0.1:9876 http://127.0.0.1:9876; media-src 'self' http://127.0.0.1:9876 blob:; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "signingIdentity": "-",
      "minimumSystemVersion": "11.0"
    },
    "resources": ["resources/context-recall-daemon"]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/JWhite212/context-recall/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
